alt-a : open -a "Activity Monitor"
alt-c : open -a "ChatGPT"
alt-d : open -a "Discord"
alt-e : open -a "Finder"
alt-b : open -a "Zen Twilight"
alt-n : open -a "Obsidian"
alt-m : open -a "Music"
alt-r : open -a "Highlights"
alt-s : open -a "Things3" && open -a "Calendar"
alt + shift - s : osascript -e 'quit app "Things3"' && osascript -e 'quit app "Calendar"'
alt-t : open -a "Kitty"
alt-v : open -a "Visual Studio Code"
alt-w : open -a "Texts"
alt-z : open -a "Zed Preview"
